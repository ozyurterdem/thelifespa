---
import '../styles/global.css';

const whatsappNumber = '905012500054';
const phoneDisplay = '0501 250 00 54';
const email = 'info@thelifespa.com';
const address = 'İstiklal Mah., Altınışık Sk. No:43/A, Serdivan/Sakarya';
const whatsappText = encodeURIComponent('Merhaba, The Life Spa için randevu oluşturmak istiyorum.');
const whatsappUrl = `https://wa.me/${whatsappNumber}?text=${whatsappText}`;

const rituals = [
  {
    title: 'TheLife Signature',
    text: 'Kişiye özel bütünsel beden terapisi.',
    meta: '90 Dakika · Bilgi Alın',
    image: 'https://images.unsplash.com/photo-1544161515-4ab6ce6db874?auto=format&fit=crop&w=900&q=85',
  },
  {
    title: 'Detox Ritüeli',
    text: 'Arınma ve dinginliği aynı seansta buluşturan bakım.',
    meta: '75 Dakika · Bilgi Alın',
    image: 'https://images.unsplash.com/photo-1608571423902-eed4a5ad8108?auto=format&fit=crop&w=900&q=85',
  },
  {
    title: 'Uzak Doğu Ritüeli',
    text: 'Geleneksel tekniklerle enerji akışını destekleyen terapi.',
    meta: '90 Dakika · Bilgi Alın',
    image: 'https://images.unsplash.com/photo-1515377905703-c4788e51af15?auto=format&fit=crop&w=900&q=85',
  },
  {
    title: 'Huzur Ritüeli',
    text: 'Sıcak taşlar ve sakin atmosferle derin gevşeme.',
    meta: '75 Dakika · Bilgi Alın',
    image: 'https://images.unsplash.com/photo-1600334129128-685c5582fd35?auto=format&fit=crop&w=900&q=85',
  },
];

const areas = [
  ['Isıtmalı Havuz', 'Yalın her mevsimde sizi dinlendirir.'],
  ['Buhar Odası', 'Nefesinizi rahatlatır, cildinizi aydınlatır.'],
  ['Sauna', 'Kaslarınızı gevşetir, kanınızı canlandırır.'],
  ['Dinlenme Alanı', 'Bitki çayları ve sessiz okuma köşeleri.'],
];

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'HealthAndBeautyBusiness',
  name: 'The Life Spa',
  url: 'https://thelife.siberkale.com',
  telephone: `+${whatsappNumber}`,
  address,
};
---

<html lang="tr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>The Life Spa | Zamansız Spa ve Wellness Deneyimi</title>
    <meta name="description" content="The Life Spa’da masaj, wellness alanları ve kişiye özel ritüellerle sessiz, sade ve lüks bir spa deneyimi yaşayın." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&family=Playfair+Display:wght@500;600;700&display=swap" rel="stylesheet" />
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  </head>
  <body>
    <main class="page-shell">
      <section class="hero" id="top">
        <header class="top-nav">
          <a class="logo" href="#top">TheLifeSpa</a>
          <nav aria-label="Ana menü">
            <a href="#ritueller">Ritüeller</a>
            <a href="#wellness">Wellness</a>
            <a href="#alanlar">Alanlar</a>
            <a href="#randevu">Randevu</a>
            <a href="#iletisim">İletişim</a>
          </nav>
          <a class="nav-button" href="#randevu">Randevu Oluştur</a>
        </header>

        <div class="hero-content">
          <p class="kicker">Zamansız. Sade. Derin içim.</p>
          <h1>Sessizliğin Lüksle Buluştuğu Spa Deneyimi</h1>
          <p>Bedeninizi, zihninizi ve ruhunuzu yenileyerek tam bir iyilik hâline ulaşın. En seçkin ritüellerle size özel wellness yolculuğu.</p>
          <div class="hero-actions">
            <a class="primary" href="#randevu">Randevu Oluştur</a>
            <a class="link-cta" href="#ritueller">Deneyim Keşfet <span>→</span></a>
          </div>
        </div>
        <a class="scroll-indicator" href="#ritueller" aria-label="Aşağı kaydır">↓</a>
      </section>

      <section class="block" id="ritueller">
        <div class="section-title row-title">
          <div><span>İmza Ritüeller</span><i></i></div>
          <a href={whatsappUrl} target="_blank" rel="noreferrer">Tüm ritüelleri görüntüle →</a>
        </div>
        <div class="ritual-grid">
          {rituals.map((ritual) => (
            <article class="ritual-card">
              <img src={ritual.image} alt={`${ritual.title} görseli`} loading="lazy" decoding="async" />
              <div>
                <h2>{ritual.title}</h2>
                <p>{ritual.text}</p>
                <small>{ritual.meta}</small>
              </div>
            </article>
          ))}
        </div>
      </section>

      <section class="wellness" id="wellness">
        <div class="wellness-copy">
          <span class="section-label">Wellness Alanları</span>
          <h2>Bedeninizi Arındırın, Ruhunuzu Dengeleyin.</h2>
          <p>Özenle tasarlanmış alanlarımızda sauna, spa ve dinginlik ritüelleri ile iyiliği deneyimleyin.</p>
          <div class="area-list">
            {areas.map(([title, text]) => (
              <div class="area-item">
                <span aria-hidden="true">◌</span>
                <div><strong>{title}</strong><p>{text}</p></div>
              </div>
            ))}
          </div>
        </div>
        <div class="wellness-gallery">
          <img class="gallery-main" src="https://images.unsplash.com/photo-1600334089648-b0d9d3028eb2?auto=format&fit=crop&w=1100&q=85" alt="Spa bakım alanı" loading="lazy" decoding="async" />
          <div>
            <img src="https://images.unsplash.com/photo-1607008829749-c0f284a498e4?auto=format&fit=crop&w=700&q=85" alt="Dinlenme alanı" loading="lazy" decoding="async" />
            <img src="https://images.unsplash.com/photo-1583416750470-965b2707b355?auto=format&fit=crop&w=700&q=85" alt="Sauna alanı" loading="lazy" decoding="async" />
            <img src="https://images.unsplash.com/photo-1519823551278-64ac92734fb1?auto=format&fit=crop&w=700&q=85" alt="Sessiz bakım odası" loading="lazy" decoding="async" />
          </div>
        </div>
      </section>

      <section class="appointment" id="randevu">
        <div class="waiting" id="iletisim">
          <img src="https://images.unsplash.com/photo-1608571423902-eed4a5ad8108?auto=format&fit=crop&w=700&q=85" alt="Minimal spa objesi" loading="lazy" decoding="async" />
          <div>
            <span class="section-label">Sizi Bekliyoruz</span>
            <h2>Zamanı Kendinize Ayırın</h2>
            <p>Randevunuzu oluşturun, size özel deneyiminizi planlayalım.</p>
            <ul>
              <li>{phoneDisplay}</li>
              <li>{email}</li>
              <li>{address}</li>
              <li>Her Gün 09:00 - 22:00</li>
            </ul>
          </div>
        </div>

        <form class="booking-form" id="bookingForm">
          <span class="section-label">Randevu Oluştur</span>
          <input name="name" autocomplete="name" placeholder="Ad Soyad" />
          <div class="form-row">
            <input name="phone" autocomplete="tel" placeholder="Telefon" />
            <input name="email" autocomplete="email" placeholder="E-posta" />
          </div>
          <select name="date"><option>Tercih Seçiniz</option><option>Bugün</option><option>Yarın</option><option>Bu hafta</option></select>
          <select name="service">
            <option>Hizmet Seçiniz</option>
            {rituals.map((ritual) => <option>{ritual.title}</option>)}
          </select>
          <button type="submit">Randevu Talebini Gönder</button>
        </form>
      </section>

      <footer class="footer">
        <div>
          <h2>TheLifeSpa</h2>
          <p>Lüksü sadelikle birleştirerek zamansız bir iyileşme ve huzur yolculuğu sunuyoruz.</p>
        </div>
        <div class="palette" aria-label="Renk paleti">
          <span style="--c:#f7f5f1">Ivory</span><span style="--c:#f0e6d6">Champagne</span><span style="--c:#e7dcc8">Soft Sand</span><span style="--c:#a9b99a">Sage</span><span style="--c:#8fa48f">Eucalyptus</span><span style="--c:#d6b96a">Soft Gold</span>
        </div>
        <div class="type-sample"><strong>Aa</strong><span>Playfair Display / Montserrat</span></div>
      </footer>
    </main>

    <script is:inline>
      const form = document.querySelector('#bookingForm');
      form?.addEventListener('submit', (event) => {
        event.preventDefault();
        const data = new FormData(form);
        const message = [
          'Merhaba, The Life Spa için randevu oluşturmak istiyorum.',
          `Ad Soyad: ${data.get('name') || '-'}`,
          `Telefon: ${data.get('phone') || '-'}`,
          `E-posta: ${data.get('email') || '-'}`,
          `Tercih: ${data.get('date') || '-'}`,
          `Hizmet: ${data.get('service') || '-'}`,
        ].join('\n');
        window.open(`https://wa.me/905012500054?text=${encodeURIComponent(message)}`, '_blank', 'noopener,noreferrer');
      });
    </script>
  </body>
</html>
