---
import '../styles/global.css';

const whatsappNumber = '905012500054';
const phoneDisplay = '0501 250 00 54';
const address = 'İstiklal Mah., Altınışık Sk. No:43/A, Serdivan/Sakarya';
const whatsappText = encodeURIComponent('Merhaba, The Life Spa için randevu oluşturmak istiyorum.');
const whatsappUrl = `https://wa.me/${whatsappNumber}?text=${whatsappText}`;

const rituals = [
  {
    title: 'İsveç Masajı',
    text: 'Spa deneyimine sakin ve dengeli başlamak isteyenler için dolaşımı destekleyen, kasları gevşetmeye odaklanan klasik masaj.',
    meta: '50 / 60 / 90 Dakika · WhatsApp ile bilgi alın',
    image: 'https://images.unsplash.com/photo-1544161515-4ab6ce6db874?auto=format&fit=crop&w=900&q=85',
  },
  {
    title: 'Medikal Taş Masaj',
    text: 'Sıcak taş dokunuşu ve terapötik masaj teknikleriyle kas gerginliği, yorgunluk ve stres hissini azaltmaya yardımcı olur.',
    meta: 'Seanslı · WhatsApp ile bilgi alın',
    image: 'https://images.unsplash.com/photo-1608571423902-eed4a5ad8108?auto=format&fit=crop&w=900&q=85',
  },
  {
    title: 'Hamam & Kese Köpük',
    text: 'Profesyonel kese köpük uygulaması, sauna ve dinlenme akışıyla bedeni arındıran geleneksel spa ritüeli.',
    meta: 'Hamam + Sauna · WhatsApp ile bilgi alın',
    image: 'https://images.unsplash.com/photo-1600334129128-685c5582fd35?auto=format&fit=crop&w=900&q=85',
  },
  {
    title: 'Çift Spa Deneyimi',
    text: 'Çift kişilik özel oda, jakuzi kullanımı ve masaj akışıyla birlikte planlanan huzurlu bir spa molası.',
    meta: 'Özel oda + Jakuzi · WhatsApp ile bilgi alın',
    image: 'https://images.unsplash.com/photo-1519823551278-64ac92734fb1?auto=format&fit=crop&w=900&q=85',
  },
];

const areas = [
  ['Yeni ve Ferah Salonlar', 'Randevu öncesi hazırlanan temiz, sakin ve konforlu bakım alanları.'],
  ['Sauna', 'Kese köpük veya masaj öncesi bedeni gevşetmeye yardımcı sıcak hazırlık alanı.'],
  ['Jakuzi', 'Tek veya çift kişilik spa molasını tamamlayan dinlendirici sıcak su deneyimi.'],
  ['Çift Kişilik Özel Oda', 'Birlikte vakit ayırmak isteyen misafirler için mahrem ve özenli spa akışı.'],
];

const highlights = ['Serdivan merkezde kolay ulaşım', 'Özel oda ve jakuzi seçenekleri', 'Kese köpük + sauna akışı', 'WhatsApp ile hızlı saat teyidi'];

const heroNotes = [
  ['Rezervasyon', 'WhatsApp ile kişisel saat teyidi'],
  ['Atmosfer', 'Sessiz, ferah ve mahrem alanlar'],
  ['Ritüel', 'Masaj + hamam + jakuzi akışı'],
];

const stats = [
  ['09:00–22:00', 'Her gün açık'],
  ['4+', 'İmza spa ritüeli'],
  ['2 kişilik', 'Özel oda seçeneği'],
];

const packages = [
  ['Arınma Molası', 'Hamam, kese köpük ve sauna ile bedeni tazeleyen kısa spa akışı.'],
  ['Derin Rahatlama', 'Medikal taş masaj ve sakin dinlenme süreciyle kas gerginliğine odaklanır.'],
  ['Çiftlere Özel', 'Özel oda, jakuzi ve masaj deneyimini birlikte yaşamak isteyenler için planlanır.'],
];

const journey = [
  ['01', 'Talebinizi iletin', 'Hizmet, gün ve kişi sayısını formdan ya da WhatsApp üzerinden paylaşın.'],
  ['02', 'Saatiniz netleşsin', 'Ekip uygun saat aralığını teyit eder ve deneyiminizi planlar.'],
  ['03', 'Alanınız hazırlansın', 'Oda, havlu ve spa akışı randevunuzdan önce özenle hazırlanır.'],
];

const experienceLayers = [
  ['Sessizlik', 'Randevu saatleri, misafirin acele hissetmeyeceği sakin bir geçişle planlanır.'],
  ['Mahremiyet', 'Tek veya çift kişilik alanlar, bakım boyunca konfor ve özel alan hissini korur.'],
  ['Ritüel Akışı', 'Sauna, hamam, jakuzi ve masaj sıralaması ihtiyaca göre birlikte kurgulanır.'],
];

const serviceMenu = [
  ['İsveç Masajı', 'İlk spa deneyimi, hafif gevşeme ve dengeli rahatlama isteyenler için.'],
  ['Medikal Taş Masaj', 'Kas gerginliği, yoğun iş temposu ve bedensel yorgunluk hissine odaklanır.'],
  ['Kese Köpük', 'Hamam ritüelinin arındırıcı etkisini profesyonel uygulamayla tamamlar.'],
  ['Sauna', 'Masaj veya hamam öncesi bedeni gevşetmeye yardımcı sıcak hazırlık alanı.'],
  ['Jakuzi', 'Seans öncesi veya sonrası özel spa molasını daha dingin hale getirir.'],
  ['Çift Konsepti', 'Özel oda, jakuzi ve masaj akışıyla birlikte planlanan iki kişilik deneyim.'],
];

const protocols = [
  ['Hazırlık', 'Oda, havlu ve kullanılacak alan randevu öncesinde hazırlanır.'],
  ['Yönlendirme', 'Misafirin seçtiği hizmete göre sauna, hamam, jakuzi veya masaj sırası netleştirilir.'],
  ['Dinlenme', 'Seans sonrası acele etmeden toparlanabileceğiniz sakin bir geçiş alanı sunulur.'],
];

const faqs = [
  ['İlk kez geliyorum, hangi hizmet uygun?', 'Rahat ve dengeli başlangıç için İsveç masajı veya hamam + kese köpük akışı önerilir. Daha yoğun kas gerginliğinde medikal taş masaj tercih edilebilir.'],
  ['Çiftler için özel alan var mı?', 'Evet. Çift kişilik özel oda, jakuzi kullanımı ve masaj akışı WhatsApp üzerinden saat teyidiyle planlanır.'],
  ['Randevu kesinleşmesi nasıl oluyor?', 'Form veya WhatsApp mesajından sonra ekip uygun saat aralığını teyit eder. Kesin randevu işletme onayıyla netleşir.'],
];

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'HealthAndBeautyBusiness',
  name: 'The Life Spa',
  url: 'https://thelife.siberkale.com',
  telephone: `+${whatsappNumber}`,
  address,
};
---

<html lang="tr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>The Life Spa Sakarya | Serdivan Premium Masaj ve Spa</title>
    <meta name="description" content="Serdivan’da premium spa deneyimi. Masaj, hamam, sauna ve jakuzi ritüelleri için The Life Spa’dan WhatsApp ile randevu alın." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600;700&family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  </head>
  <body>
    <main class="page-shell">
      <section class="hero" id="top">
        <header class="top-nav">
          <a class="logo" href="#top">The Life</a>
          <nav aria-label="Ana menü">
            <a href="#ritueller">Ritüeller</a>
            <a href="#wellness">Wellness</a>
            <a href="#paketler">Paketler</a>
            <a href="#randevu">Randevu</a>
            <a href="#iletisim">İletişim</a>
          </nav>
          <a class="nav-button" href="#randevu">Randevu Oluştur</a>
        </header>

        <div class="hero-content">
          <p class="kicker">Serdivan’da sakin ve seçkin bir spa molası</p>
          <h1>Sessizliğin Lüksle Buluştuğu Spa Deneyimi</h1>
          <p>The Life Spa; İsveç masajı, medikal taş masaj, hamam, sauna, jakuzi ve çiftlere özel spa deneyimini ferah salonlarda profesyonel uygulama anlayışıyla sunar.</p>
          <div class="hero-actions">
            <a class="primary" href="#randevu">Randevu Oluştur</a>
            <a class="link-cta" href="#ritueller">Deneyim Keşfet <span>→</span></a>
          </div>
        </div>

        <aside class="hero-concierge" aria-label="The Life Spa kısa bilgi">
          <span>Concierge</span>
          <strong>{phoneDisplay}</strong>
          <p>Seans öncesi uygun saat, hizmet seçimi ve çift oda talebiniz WhatsApp üzerinden netleştirilir.</p>
          <div>
            {heroNotes.map(([title, text]) => (
              <dl><dt>{title}</dt><dd>{text}</dd></dl>
            ))}
          </div>
        </aside>
        <a class="scroll-indicator" href="#ritueller" aria-label="Aşağı kaydır">↓</a>
      </section>

      <section class="stat-strip" aria-label="The Life Spa kısa istatistikler">
        {stats.map(([value, label]) => (
          <div><strong>{value}</strong><span>{label}</span></div>
        ))}
      </section>

      <section class="trust-band" aria-label="Öne çıkan özellikler">
        {highlights.map((item) => <span>{item}</span>)}
      </section>

      <section class="block intro-block">
        <div class="intro-copy">
          <span class="section-label">The Life yaklaşımı</span>
          <h2>Rahatlama hissi kapıdan girdiğiniz anda başlar.</h2>
        </div>
        <p>Hızlı tüketilen bir bakım yerine, sakinleşmeye zaman tanıyan bir deneyim tasarlıyoruz. Salon hazırlığından seans akışına kadar her adım; mahremiyet, hijyen ve konfor hissini koruyacak şekilde planlanır.</p>
      </section>

      <section class="block rituals-section" id="ritueller">
        <div class="section-title row-title">
          <div><span>İmza Ritüeller</span><i></i></div>
          <a href={whatsappUrl} target="_blank" rel="noreferrer">Uygun saat sor →</a>
        </div>
        <div class="ritual-grid">
          {rituals.map((ritual) => (
            <article class="ritual-card">
              <figure>
                <img src={ritual.image} alt={`${ritual.title} görseli`} loading="lazy" decoding="async" />
              </figure>
              <div>
                <span class="card-kicker">Signature Treatment</span>
                <h2>{ritual.title}</h2>
                <p>{ritual.text}</p>
                <small>{ritual.meta}</small>
              </div>
            </article>
          ))}
        </div>
      </section>

      <section class="experience-layers">
        <div class="layer-heading">
          <span class="section-label">Deneyimin Katmanları</span>
          <h2>Lüks burada gösteriş değil, iyi düşünülmüş sessizliktir.</h2>
        </div>
        <div class="layer-grid">
          {experienceLayers.map(([title, text]) => (
            <article>
              <h3>{title}</h3>
              <p>{text}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="wellness" id="wellness">
        <div class="wellness-copy">
          <span class="section-label">Wellness Alanları</span>
          <h2>Yoğun Günün Ardından Kendinize Alan Açın.</h2>
          <p>İş ve yaşam temposundan uzaklaşmak, gevşemek ve stresten arınmak için hazırlanan spa akışında her detay konfor, temizlik ve sakinlik hissini güçlendirmek için planlanır.</p>
          <div class="area-list">
            {areas.map(([title, text]) => (
              <div class="area-item">
                <span aria-hidden="true">◌</span>
                <div><strong>{title}</strong><p>{text}</p></div>
              </div>
            ))}
          </div>
        </div>
        <div class="wellness-gallery">
          <img class="gallery-main" src="https://images.unsplash.com/photo-1600334089648-b0d9d3028eb2?auto=format&fit=crop&w=1100&q=85" alt="Spa bakım alanı" loading="lazy" decoding="async" />
          <div>
            <img src="https://images.unsplash.com/photo-1607008829749-c0f284a498e4?auto=format&fit=crop&w=700&q=85" alt="Dinlenme alanı" loading="lazy" decoding="async" />
            <img src="https://images.unsplash.com/photo-1583416750470-965b2707b355?auto=format&fit=crop&w=700&q=85" alt="Sauna alanı" loading="lazy" decoding="async" />
            <img src="https://images.unsplash.com/photo-1519823551278-64ac92734fb1?auto=format&fit=crop&w=700&q=85" alt="Sessiz bakım odası" loading="lazy" decoding="async" />
          </div>
        </div>
      </section>

      <section class="service-menu">
        <div class="menu-title">
          <span class="section-label">Hizmet Menüsü</span>
          <h2>İhtiyacınızı tek bir başlıkla değil, doğru akışla ele alırız.</h2>
        </div>
        <div class="menu-list">
          {serviceMenu.map(([title, text]) => (
            <article>
              <h3>{title}</h3>
              <p>{text}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="packages" id="paketler">
        <div class="package-hero">
          <span class="section-label">Özel Spa Akışları</span>
          <h2>Tek bir işlem değil, tamamlanmış bir mola.</h2>
          <p>Hizmetleri tek tek seçebilir veya ihtiyacınıza göre bir spa akışı oluşturabilirsiniz. Fiyat ve uygunluk bilgisi WhatsApp üzerinden netleştirilir.</p>
        </div>
        <div class="package-list">
          {packages.map(([title, text]) => (
            <article>
              <h3>{title}</h3>
              <p>{text}</p>
              <a href={whatsappUrl} target="_blank" rel="noreferrer">Bilgi al →</a>
            </article>
          ))}
        </div>
      </section>

      <section class="protocol">
        <div class="protocol-copy">
          <span class="section-label">Hazırlık Protokolü</span>
          <h2>Premium his, seans başlamadan önce kurulur.</h2>
          <p>Misafirin deneyimi sadece uygulama anından ibaret değildir. Odanın hazırlanması, akışın sıralanması ve seans sonrası dinlenme geçişi aynı bütünün parçalarıdır.</p>
        </div>
        <div class="protocol-list">
          {protocols.map(([title, text]) => (
            <article>
              <span></span>
              <div><h3>{title}</h3><p>{text}</p></div>
            </article>
          ))}
        </div>
      </section>

      <section class="journey">
        <div class="journey-title">
          <span class="section-label">Randevu Akışı</span>
          <h2>Sakin bir deneyim için randevunuz önceden hazırlanır.</h2>
        </div>
        <div class="journey-steps">
          {journey.map(([number, title, text]) => (
            <article>
              <span>{number}</span>
              <h3>{title}</h3>
              <p>{text}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="faq-section">
        <div class="faq-title">
          <span class="section-label">Sık Sorulanlar</span>
          <h2>Gelmeden önce bilmek isteyecekleriniz.</h2>
        </div>
        <div class="faq-list">
          {faqs.map(([question, answer]) => (
            <article>
              <h3>{question}</h3>
              <p>{answer}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="quote-panel">
        <p>“Yoğun ve stresli geçen bir günün ardından, kendinize ayırdığınız zamanın gerçekten sakin hissettirmesi gerekir.”</p>
        <span>The Life Spa & Masaj · Serdivan</span>
      </section>

      <section class="appointment" id="randevu">
        <div class="waiting" id="iletisim">
          <img src="https://images.unsplash.com/photo-1608571423902-eed4a5ad8108?auto=format&fit=crop&w=700&q=85" alt="Minimal spa objesi" loading="lazy" decoding="async" />
          <div>
            <span class="section-label">Sizi Bekliyoruz</span>
            <h2>Zamanı Kendinize Ayırın</h2>
            <p>Masaj, hamam, sauna, jakuzi veya çift spa talebinizi iletin; size uygun saat aralığını WhatsApp üzerinden netleştirelim.</p>
            <ul>
              <li>{phoneDisplay}</li>
              <li>WhatsApp: {phoneDisplay}</li>
              <li>{address}</li>
              <li>Her Gün 09:00 - 22:00</li>
            </ul>
          </div>
        </div>

        <form class="booking-form" id="bookingForm">
          <span class="section-label">Randevu Oluştur</span>
          <input name="name" autocomplete="name" placeholder="Ad Soyad" aria-label="Ad Soyad" />
          <div class="form-row">
            <input name="phone" autocomplete="tel" placeholder="Telefon" aria-label="Telefon" />
            <input name="email" autocomplete="email" placeholder="E-posta" aria-label="E-posta" />
          </div>
          <select name="date" aria-label="Tercih edilen tarih"><option>Tercih Edilen Gün</option><option>Bugün</option><option>Yarın</option><option>Bu hafta</option></select>
          <select name="service" aria-label="Hizmet seçiniz">
            <option>Hizmet Seçiniz</option>
            {rituals.map((ritual) => <option>{ritual.title}</option>)}
          </select>
          <button type="submit">Randevu Talebini Gönder</button>
        </form>
      </section>

      <footer class="footer">
        <div class="footer-brand">
          <span class="footer-mark">The Life</span>
          <p>Serdivan’da masaj, hamam, sauna, jakuzi ve çiftlere özel spa deneyimini sakin, ferah ve profesyonel bir atmosferde sunuyoruz.</p>
          <a class="footer-cta" href={whatsappUrl} target="_blank" rel="noreferrer">WhatsApp ile Randevu Al</a>
        </div>

        <div class="footer-column" aria-label="Hizmetler">
          <span>Hizmetler</span>
          <a href="#ritueller">İsveç Masajı</a>
          <a href="#ritueller">Medikal Taş Masaj</a>
          <a href="#ritueller">Hamam & Kese Köpük</a>
          <a href="#ritueller">Çift Spa Deneyimi</a>
        </div>

        <div class="footer-column" aria-label="Deneyim">
          <span>Deneyim</span>
          <a href="#wellness">Wellness Alanları</a>
          <a href="#paketler">Özel Spa Akışları</a>
          <a href="#randevu">Randevu Akışı</a>
          <a href="#iletisim">İletişim</a>
        </div>

        <div class="footer-contact">
          <span>Rezervasyon</span>
          <strong>{phoneDisplay}</strong>
          <p>{address}</p>
          <p>Her Gün 09:00 - 22:00</p>
        </div>
      </footer>
    </main>

    <script is:inline>
      const form = document.querySelector('#bookingForm');
      form?.addEventListener('submit', (event) => {
        event.preventDefault();
        const data = new FormData(form);
        const message = [
          'Merhaba, The Life Spa için randevu oluşturmak istiyorum.',
          `Ad Soyad: ${data.get('name') || '-'}`,
          `Telefon: ${data.get('phone') || '-'}`,
          `E-posta: ${data.get('email') || '-'}`,
          `Tercih: ${data.get('date') || '-'}`,
          `Hizmet: ${data.get('service') || '-'}`,
        ].join('\n');
        window.open(`https://wa.me/905012500054?text=${encodeURIComponent(message)}`, '_blank', 'noopener,noreferrer');
      });
    </script>
  </body>
</html>
