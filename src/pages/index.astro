---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import StatStrip from '../components/StatStrip.astro';
import TrustBand from '../components/TrustBand.astro';
import Intro from '../components/Intro.astro';
import Rituals from '../components/Rituals.astro';
import ExperienceLayers from '../components/ExperienceLayers.astro';
import Wellness from '../components/Wellness.astro';
import ServiceMenu from '../components/ServiceMenu.astro';
import Packages from '../components/Packages.astro';
import Protocol from '../components/Protocol.astro';
import Journey from '../components/Journey.astro';
import Faq from '../components/Faq.astro';
import QuotePanel from '../components/QuotePanel.astro';
import Appointment from '../components/Appointment.astro';
import Footer from '../components/Footer.astro';
import StickyCta from '../components/StickyCta.astro';
---
<BaseLayout>
  <main class="page-shell">
    <Hero />
    <StatStrip />
    <TrustBand />
    <Intro />
    <Rituals />
    <ExperienceLayers />
    <Wellness />
    <ServiceMenu />
    <Packages />
    <Protocol />
    <Journey />
    <Faq />
    <QuotePanel />
    <Appointment />
    <Footer />
  </main>
  <StickyCta />
</BaseLayout>
